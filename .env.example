# /RooT-Camp — variabili d'ambiente
# Copia questo file in .env e compila i valori. Non versionare/non deployare .env.

# --- App ---
APP_ENV=production            # production | development
APP_URL=https://rootcamp.rootclub.it
APP_TIMEZONE=Europe/Rome
SESSION_LIFETIME=7200

# Token monouso per /admin/setup.php (creazione del primo admin).
# Generalo random (es. `openssl rand -hex 32`), incollalo qui, poi
# dopo aver creato il primo utente svuota questa variabile.
SETUP_TOKEN=

# --- Database (MariaDB) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=rootcamp
DB_USER=
DB_PASS=
DB_CHARSET=utf8mb4

# --- SMTP (per mail di conferma iscrizione) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=camp@rootclub.it
SMTP_FROM_NAME=/RooT-Camp
SMTP_SECURE=tls               # tls | ssl | none
